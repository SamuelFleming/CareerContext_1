{
  "paths": {
    "/": {
      "get": {
        "tags": ["Health"],
        "summary": "API root",
        "description": "Returns a short message confirming the API is running.",
        "operationId": "getApiRoot",
        "x-api-id": "API-ROOT",
        "security": [],
        "responses": {
          "200": {
            "description": "API running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "CareerContext API running" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Lightweight health probe for local development.",
        "operationId": "getHealth",
        "x-api-id": "API-HEALTH",
        "security": [],
        "responses": {
          "200": {
            "description": "Service healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "CareerContext API health check" },
                    "status": { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "careerContext-api" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
