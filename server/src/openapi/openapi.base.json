{
  "openapi": "3.0.3",
  "info": {
    "title": "CareerContext API",
    "version": "1.0.0",
    "description": "OpenAPI document for **implemented** CareerContext API endpoints only.\n\nUse Swagger UI to browse and test live routes. Planned or stub endpoints are documented in `docs/core-scope/08_api_contract.md` (API design intent), not here.\n\nSpec files: `server/src/openapi/`."
  },
  "servers": [
    {
      "url": "/api",
      "description": "CareerContext API base path"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "API root and health check"
    },
    {
      "name": "Auth",
      "description": "Registration, login, and current user"
    },
    {
      "name": "Dashboard",
      "description": "Dashboard summary and Interactive CV"
    },
    {
      "name": "Profile",
      "description": "Profile and core context"
    },
    {
      "name": "Experiences",
      "description": "Experience evidence CRUD and workspace"
    },
    {
      "name": "Activities",
      "description": "Activity evidence CRUD"
    }
  ],
  "paths": {},
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT from `POST /auth/register` or `POST /auth/login`. Use Authorize in Swagger UI."
      }
    },
    "schemas": {
      "ErrorBody": {
        "type": "object",
        "required": ["message", "code"],
        "properties": {
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        }
      },
      "AuthErrorCode": {
        "type": "string",
        "enum": ["AUTH_REQUIRED", "TOKEN_EXPIRED", "TOKEN_INVALID"]
      },
      "DataEnvelope": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "MessageDataEnvelope": {
        "type": "object",
        "required": ["message", "data"],
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "ListMeta": {
        "type": "object",
        "required": ["count", "total", "limit", "offset", "hasMore"],
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "total": {
            "type": "integer",
            "minimum": 0
          },
          "limit": {
            "type": "integer",
            "minimum": 1
          },
          "offset": {
            "type": "integer",
            "minimum": 0
          },
          "hasMore": {
            "type": "boolean"
          }
        }
      },
      "ListEnvelope": {
        "type": "object",
        "required": ["data", "meta"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "meta": {
            "$ref": "#/components/schemas/ListMeta"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing, expired, or invalid JWT",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "authRequired": {
                "value": {
                  "error": {
                    "message": "Not authenticated",
                    "code": "AUTH_REQUIRED"
                  }
                }
              },
              "tokenExpired": {
                "value": {
                  "error": {
                    "message": "Session has expired",
                    "code": "TOKEN_EXPIRED"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
